# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Django secret key — used for cryptographic signing.
# Generate one at: https://djecrety.ir  or run:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# OpenRouteService API key — used for geocoding and routing.
# Sign up for a free key at: https://openrouteservice.org/dev/#/signup
# After login go to Dashboard → Tokens → Request a token
OPENROUTE_API_KEY=your-openrouteservice-api-key-here

# Set to False in production.
DEBUG=True

# Comma-separated list of allowed frontend origins.
# Example for multiple: http://localhost:5173,https://yourapp.com
CORS_ALLOWED_ORIGINS=http://localhost:5173
